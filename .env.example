# The Odds API (the-odds-api.com) keys, comma-separated for multi-key rotation
# Used by Pre_Match.py and Odds_Pre_Match.py
ODDS_API_KEYS=key1,key2,key3

# Sportradar NBA API (api.sportradar.us/nba) keys, comma-separated for multi-key rotation
# Used by validate.py
SPORTRADAR_API_KEYS=key1,key2,key3

# Azure PostgreSQL password (winbets-predictions.postgres.database.azure.com, user=winbets)
# Used by validate.py and save.py
DB_PASSWORD=your-database-password
